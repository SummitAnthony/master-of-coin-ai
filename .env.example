# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — never commit real API keys.

# Which LLM backend to use: gemini | openai | anthropic | ollama
LLM_PROVIDER=gemini

# Gemini (free tier). Create a key at https://aistudio.google.com
GEMINI_API_KEY=

# Optional alternative providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Company profile (all optional; defaults shown) -------------------------
# These brand the reports, prompts, and dashboard for your company.
COMPANY_NAME=Your Company
GROUP_NAME=
CURRENCY=USD
VOLUME_UNIT=MT
# Month your fiscal year ends (1-12). 12 = calendar year; 6 = July-June FY.
FISCAL_YEAR_END_MONTH=12
